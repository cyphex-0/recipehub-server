PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
# Option A (recommended): paste your full connection string here.
# Atlas example:
#   MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/recipehub?retryWrites=true&w=majority
# Local example:
#   MONGODB_URI=mongodb://localhost:27017
MONGODB_URI=


# Auth (legacy JWT — kept for now, unused after Better Auth refactor)
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# === Better Auth ===
# Required. Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace_with_a_long_random_string_min_32_chars
# Public URL where the server is reachable (used for OAuth callbacks + cookie domain).
BETTER_AUTH_URL=http://localhost:5000

# === Google OAuth (used by Better Auth socialProviders.google) ===
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  http://localhost:5000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PREMIUM_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
